# ================================================================
# PROCUREMENT SYSTEM — Environment Configuration
# Copy this file to .env and update values before running
# ================================================================

# Django
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database — SQL Server
MSSQL_SA_PASSWORD=StrongP@ss123!
DB_NAME=ProcurementDB
DB_HOST=db
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=StrongP@ss123!

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Procurement System <no-reply@yourcompany.com>

# Storage (set to 's3' for cloud, 'local' for local filesystem)
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1

# App
SITE_URL=http://localhost
QUOTATION_TOKEN_EXPIRY_HOURS=72
SESSION_COOKIE_AGE=28800
